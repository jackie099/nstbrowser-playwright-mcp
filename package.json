{
  "name": "nstbrowser-playwright-mcp",
  "version": "1.0.0",
  "description": "MCP server combining NSTBrowser profile management with Playwright browser automation via CDP",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "nstbrowser-playwright-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/"
  },
  "keywords": [
    "mcp",
    "nstbrowser",
    "playwright",
    "browser-automation",
    "cdp",
    "model-context-protocol"
  ],
  "license": "MIT",
  "engines": {
